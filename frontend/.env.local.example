# ============================================================
# FRONTEND ENVIRONMENT — copy to .env.local and fill in real values
# ============================================================

# Clerk Auth (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (do not change)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Backend API URL
# Local dev: http://localhost:8000
# Production: https://your-backend.onrender.com (or Fly/Railway URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe publishable key (leave blank to skip billing UI)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
