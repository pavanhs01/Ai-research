# ============================================================
# BACKEND ENVIRONMENT — copy to .env and fill in real values
# ============================================================

# App
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_assistant

# Clerk Auth (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...

# OpenAI
# Production: set this ONLY in your hosting platform's environment dashboard (Render/Fly/Railway).
# Never commit a real key here.
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store
# Use "chroma" for local dev (zero setup), "pinecone" for production
VECTOR_STORE_PROVIDER=chroma
CHROMA_DB_PATH=./chroma_data

# Pinecone (production only - leave blank for local dev)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=

# AWS S3 file storage (leave blank to skip file storage in local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Stripe billing (leave blank to skip billing in local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe Dashboard (Product catalog > Pricing) — required to create checkout sessions
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
